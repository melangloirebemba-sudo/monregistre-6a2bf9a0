 .gitignore                                    |   2 +
 android/app/.gitignore                        |   1 +
 android/app/build.gradle                      |   6 +-
 android/app/capacitor.build.gradle            |   3 +
 android/app/monregistre.keystore              | Bin 2754 -> 0 bytes
 android/capacitor.settings.gradle             |   9 +
 capacitor.config.ts                           |  15 +-
 package-lock.json                             | 330 ++++++------------
 package.json                                  |   7 +
 src/components/app/capacitor-live-updater.tsx |  39 +++
 src/hooks/use-offline-status.ts               |  23 ++
 src/lib/offline-queue.ts                      |  26 +-
 src/routeTree.gen.ts                          |  10 +
 src/router.tsx                                |  27 ++
 src/routes/__root.tsx                         |   2 +
 vite.config.mobile.ts                         |  21 ++
 17 files changed, 335 insertions(+), 226 deletions(-)
 delete mode 100644 android/app/monregistre.keystore
 create mode 100644 src/components/app/capacitor-live-updater.tsx
 create mode 100644 vite.config.mobile.ts

diff --git a/.github/workflows/build-android-apk.yml b/.github/workflows/build-android-apk.yml
index 8bad6c5..404ddc6 100644
--- a/.github/workflows/build-android-apk.yml
+++ b/.github/workflows/build-android-apk.yml
@@ -7,6 +7,9 @@ on:
     paths:
       - "android/**"
       - "capacitor.config.ts"
+      - "vite.config.mobile.ts"
+      - "src/**"
+      - "package.json"
       - ".github/workflows/build-android-apk.yml"
 
 jobs:
@@ -30,18 +33,49 @@ jobs:
       - name: Install dependencies
         run: npm install
 
+      - name: Build offline-capable web bundle
+        run: npm run build:mobile
+
       - name: Sync Capacitor
         run: npx cap sync android
 
       - name: Grant execute permission to gradlew
         run: chmod +x android/gradlew
 
-      - name: Build release APK
+      - name: Decode release keystore
+        env:
+          KEYSTORE_BASE64: ${{ secrets.MONREGISTRE_KEYSTORE_BASE64 }}
+        run: |
+          if [ -n "$KEYSTORE_BASE64" ]; then
+            echo "$KEYSTORE_BASE64" | base64 -d > android/app/monregistre-release.keystore
+            echo "HAS_KEYSTORE=true" >> "$GITHUB_ENV"
+          else
+            echo "HAS_KEYSTORE=false" >> "$GITHUB_ENV"
+          fi
+
+      - name: Build signed release APK
+        if: env.HAS_KEYSTORE == 'true'
         working-directory: android
+        env:
+          MONREGISTRE_KEYSTORE_PATH: monregistre-release.keystore
+          MONREGISTRE_KEYSTORE_PASSWORD: ${{ secrets.MONREGISTRE_KEYSTORE_PASSWORD }}
         run: ./gradlew assembleRelease --no-daemon
 
-      - name: Upload APK
+      - name: Build debug APK (fallback — no keystore secret configured yet)
+        if: env.HAS_KEYSTORE != 'true'
+        working-directory: android
+        run: ./gradlew assembleDebug --no-daemon
+
+      - name: Upload release APK
+        if: env.HAS_KEYSTORE == 'true'
+        uses: actions/upload-artifact@v4
+        with:
+          name: MonRegistre-release-apk
+          path: android/app/build/outputs/apk/release/app-release.apk
+
+      - name: Upload debug APK
+        if: env.HAS_KEYSTORE != 'true'
         uses: actions/upload-artifact@v4
         with:
           name: MonRegistre-debug-apk
-	  path: android/app/build/outputs/apk/debug/app-debug.apk
+          path: android/app/build/outputs/apk/debug/app-debug.apk
